<%- include('../partials/header') %>
<link rel="stylesheet" href="/styles/styles.css">

<main class="hero">
    <h1>Ficha de Atendimento - Apometria</h1>
    
    <form action="/atendimento/salvar" method="POST" class="form-container" id="atendimentoForm">
        <input type="hidden" name="tipo" value="apometria">
        <input type="hidden" name="idSolicitacao" id="idSolicitacao">
        
        <div class="form-row">
            <div class="form-group">
                <label>Data:</label>
                <input type="date" name="data" id="campo_data" required>
            </div>
            <div class="form-group flex-2">
                <label>CPF:</label>
                <input type="text" id="cpf_assistido" name="cpf_assistido" placeholder="Apenas numeros" required autocomplete="off" inputmode="numeric" maxlength="14">
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Nome:</label>
                <input type="text" name="nome_assistido" id="campo_nome" required>
            </div>
            <div class="form-group">
                <label>Idade:</label>
                <input type="text" name="idade_assistido" id="campo_idade">
            </div>
            <div class="form-group">
                <label>Religiao:</label>
                <input type="text" name="religiao_assistido" id="campo_religiao">
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Terapeuta Responsavel:</label>
                <input type="text" name="voluntario" id="voluntario" required>
            </div>
        </div>

        <div class="form-group">
            <label>Evolucao do Atendimento:</label>
            <textarea name="observacoes" id="descricao_atendimento" rows="5" required></textarea>
        </div>
        <br><br>
        <button type="submit" class="btn-atender btn-success">Finalizar Atendimento</button>
    </form><br><br>

    <hr>
    <h3>Historico de Atendimentos</h3>
    <table class="table-historico">
        <thead>
            <tr>
                <th>Data</th>
                <th>Terapeuta</th>
                <th>Observacao</th>
            </tr>
        </thead>
        <tbody id="tabela-corpo">
            <tr><td colspan="3">Aguardando CPF...</td></tr>
        </tbody>
    </table>
</main>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    const dataHoje = new Date().toISOString().split('T')[0];
    document.getElementById('campo_data').value = dataHoje;
    const campoCpf = document.getElementById('cpf_assistido');
    let ultimoCpfSemCadastroAlertado = '';
    let ultimoCpfIncompletoAlertado = '';

    function normalizarCpf(valor) {
        return (valor || '').replace(/\D/g, '');
    }

    function cpfTem11Digitos(valor) {
        return normalizarCpf(valor).length === 11;
    }

    async function buscarAssistidoPorCpf(cpf) {
        const resposta = await fetch(`/api/dados-assistido/${cpf}`);
        if (!resposta.ok) {
            return null;
        }

        return resposta.json();
    }

    function calcularIdade(dataNasc) {
        if (!dataNasc) return '';
        const hoje = new Date();
        const nasc = new Date(dataNasc);
        let idade = hoje.getFullYear() - nasc.getFullYear();
        const m = hoje.getMonth() - nasc.getMonth();
        if (m < 0 || (m === 0 && hoje.getDate() < nasc.getDate())) idade--;
        return idade;
    }

    function renderizarTabela(lista) {
        const corpo = document.getElementById('tabela-corpo');
        if (!lista || lista.length === 0) {
            corpo.innerHTML = '<tr><td colspan="3">Nenhum historico encontrado.</td></tr>';
            return;
        }
        corpo.innerHTML = lista.map(item => `
            <tr>
                <td>${new Date(item.data).toLocaleDateString('pt-BR')}</td>
                <td>${item.voluntario || '-'}</td>
                <td>${item.observacoes || '-'}</td>
            </tr>
        `).join('');
    }

    campoCpf.addEventListener('blur', async (e) => {
        const cpf = normalizarCpf(e.target.value);
        if (!cpfTem11Digitos(cpf)) {
            if (cpf.length > 0 && ultimoCpfIncompletoAlertado !== cpf) {
                ultimoCpfIncompletoAlertado = cpf;
                await Swal.fire('CPF incompleto', 'Informe um CPF com 11 digitos.', 'warning');
            }
            return;
        }

        ultimoCpfIncompletoAlertado = '';
        ultimoCpfSemCadastroAlertado = '';

        document.getElementById('idSolicitacao').value = `${cpf}_${dataHoje}`;

        try {
            const assistido = await buscarAssistidoPorCpf(cpf);
            if (!assistido) {
                document.getElementById('campo_nome').value = '';
                document.getElementById('campo_religiao').value = '';
                document.getElementById('campo_idade').value = '';
                renderizarTabela([]);
                if (ultimoCpfSemCadastroAlertado !== cpf) {
                    ultimoCpfSemCadastroAlertado = cpf;
                    await Swal.fire('Assistido não encontrado', 'Este CPF ainda não está cadastrado. Faça o cadastro antes de registrar o atendimento.', 'warning');
                }
                return;
            }

            ultimoCpfSemCadastroAlertado = '';
            document.getElementById('campo_nome').value = assistido.nome_assistido || '';
            document.getElementById('campo_religiao').value = assistido.religiao_assistido || '';
            document.getElementById('campo_idade').value = calcularIdade(assistido.data_nascimento_assistido);

            const respB = await fetch(`/api/historico/apometria/${cpf}`);
            if (respB.ok) {
                const dataRes = await respB.json();

                if (dataRes.queixa_atual) {
                    const campoObs = document.getElementById('descricao_atendimento');
                    const textoQueixa = `RELATO NA TRIAGEM:\n${dataRes.queixa_atual}\n-----------------------------\nORIENTACOES:\n`;

                    if (campoObs.value.trim() === '') {
                        campoObs.value = textoQueixa;
                    }
                }
                renderizarTabela(dataRes.historico || []);
            }
        } catch (err) {
            console.error('Erro na busca:', err);
        }
    });

    document.getElementById('atendimentoForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = e.target.querySelector('button');

        if (!cpfTem11Digitos(campoCpf.value)) {
            await Swal.fire('CPF invalido', 'Informe um CPF com 11 digitos antes de finalizar.', 'warning');
            campoCpf.focus();
            return;
        }

        btn.disabled = true;

        try {
            const assistido = await buscarAssistidoPorCpf(normalizarCpf(campoCpf.value));
            if (!assistido) {
                await Swal.fire('Assistido nao encontrado', 'Este CPF ainda nao esta cadastrado. Faca o cadastro antes de finalizar o atendimento.', 'warning');
                campoCpf.focus();
                btn.disabled = false;
                return;
            }

            ultimoCpfSemCadastroAlertado = '';
            const formData = new URLSearchParams(new FormData(e.target));
            const resp = await fetch(e.target.action, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: formData
            });

            if (resp.ok) {
                await Swal.fire('Sucesso', 'Atendimento salvo e encaminhado para o Passe!', 'success');
                window.location.href = '/fila-atendimento';
            } else {
                const erro = await resp.json().catch(() => null);
                throw new Error(erro?.mensagem || 'Falha ao salvar atendimento.');
            }
        } catch (err) {
            Swal.fire('Erro', err.message || 'Falha ao salvar atendimento.', 'error');
            btn.disabled = false;
        }
    });
</script>

<%- include('../partials/footer') %>
