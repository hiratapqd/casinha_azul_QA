<%- include('../partials/header') %>
<link rel="stylesheet" href="/styles/styles.css">

<main class="hero">
    <h1>Ficha de Atendimento - Apometria</h1>
    
    <form action="/atendimento/salvar" method="POST" class="form-container" id="atendimentoForm">
        <input type="hidden" name="tipo" value="apometria">
        <input type="hidden" name="idSolicitacao" id="idSolicitacao">
        
        <div class="form-row">
            <div class="form-group">
                <label>Data:</label>
                <input type="date" name="data" id="campo_data" required>
            </div>
            <div class="form-group flex-2">
                <label>CPF:</label>
                <input type="text" id="cpf_assistido" name="cpf_assistido" placeholder="Apenas números" required autocomplete="off">
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Nome:</label>
                <input type="text" name="nome_assistido" id="campo_nome" required>
            </div>
            <div class="form-group">
                <label>Idade:</label>
                <input type="text" name="idade_assistido" id="campo_idade">
            </div>
            <div class="form-group">
                <label>Religião:</label>
                <input type="text" name="religiao_assistido" id="campo_religiao">
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Terapeuta Responsável:</label>
                <input type="text" name="voluntario" id="voluntario" required>
            </div>
        </div>

        <div class="form-group">
            <label>Evolução do Atendimento:</label>
            <textarea name="observacoes" id="descricao_atendimento" rows="5" required></textarea>
        </div>
        <br><br>
        <button type="submit" class="btn-atender btn-success">Finalizar Atendimento</button>
    </form><br><br>    

    <hr>
    <h3>Histórico de Atendimentos</h3>
    <table class="table-historico">
        <thead>
            <tr>
                <th>Data</th>
                <th>Terapeuta</th>
                <th>Observação</th>
            </tr>
        </thead>
        <tbody id="tabela-corpo">
            <tr><td colspan="3">Aguardando CPF...</td></tr>
        </tbody>
    </table>
</main>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    // 1. Configuração de Data (Formato ISO para o MongoDB)
    const dataHoje = new Date().toISOString().split('T')[0];
    document.getElementById('campo_data').value = dataHoje;

    function calcularIdade(dataNasc) {
        if (!dataNasc) return '';
        const hoje = new Date();
        const nasc = new Date(dataNasc);
        let idade = hoje.getFullYear() - nasc.getFullYear();
        const m = hoje.getMonth() - nasc.getMonth();
        if (m < 0 || (m === 0 && hoje.getDate() < nasc.getDate())) idade--;
        return idade;
    }

    function renderizarTabela(lista) {
        const corpo = document.getElementById('tabela-corpo');
        if (!lista || lista.length === 0) {
            corpo.innerHTML = '<tr><td colspan="3">Nenhum histórico encontrado.</td></tr>';
            return;
        }
        corpo.innerHTML = lista.map(item => `
            <tr>
                <td>${new Date(item.data).toLocaleDateString('pt-BR')}</td>
                <td>${item.voluntario || '-'}</td>
                <td>${item.observacoes || '-'}</td>
            </tr>
        `).join('');
    }

    // 2. Busca de Dados, Queixa e Histórico
    document.getElementById('cpf_assistido').addEventListener('blur', async (e) => {
        const cpf = e.target.value.replace(/\D/g, '');
        if (cpf.length === 11) {
            // Define o ID da solicitação para o Controller dar baixa
            document.getElementById('idSolicitacao').value = `${cpf}_${dataHoje}`;

            try {
                // Busca Dados do Assistido
                const respA = await fetch(`/api/dados-assistido/${cpf}`);
                if (respA.ok) {
                    const assistido = await respA.json();
                    if (assistido) {
                        document.getElementById('campo_nome').value = assistido.nome_assistido || '';
                        document.getElementById('campo_religiao').value = assistido.religiao_assistido || '';
                        document.getElementById('campo_idade').value = calcularIdade(assistido.data_nascimento_assistido);
                    }
                }

                // Busca Histórico e Queixa Atual
                const respB = await fetch(`/api/historico/apometria/${cpf}`);
                if (respB.ok) {
                    const dataRes = await respB.json();
                    
                    // CORREÇÃO: Usando 'queixa_atual' conforme AtendimentoController.js
                    if (dataRes.queixa_atual) {
                        const campoObs = document.getElementById('descricao_atendimento');
                        const textoQueixa = `QUEIXA NA RECEPÇÃO:\n${dataRes.queixa_atual}\n-----------------------------\nORIENTAÇÕES:\n`;
                        
                        if (campoObs.value.trim() === "") {
                            campoObs.value = textoQueixa;
                        }
                    }
                    renderizarTabela(dataRes.historico || []);
                }
            } catch (err) {
                console.error("Erro na busca:", err);
            }
        }
    });

    // 3. Envio do Formulário
    document.getElementById('atendimentoForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = e.target.querySelector('button');
        btn.disabled = true;

        try {
            const formData = new URLSearchParams(new FormData(e.target));
            const resp = await fetch(e.target.action, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: formData
            });

            if (resp.ok) {
                await Swal.fire('Sucesso', 'Atendimento salvo e encaminhado para o Passe!', 'success');
                window.location.href = '/fila-atendimento';
            } else {
                throw new Error();
            }
        } catch (err) {
            Swal.fire('Erro', 'Falha ao salvar atendimento.', 'error');
            btn.disabled = false;
        }
    });
</script>

<%- include('../partials/footer') %>