<%- include('../partials/header') %>
<link rel="stylesheet" href="/styles/styles.css">

<main class="hero">
    <h1><%= titulo %></h1>

    <form action="<%= action %>" method="POST" class="form-container" id="atendimentoForm">
        <input type="hidden" name="tipo" value="<%= tipo %>">
        <input type="hidden" name="idSolicitacao" id="idSolicitacao">

        <div class="form-row">
            <div class="form-group">
                <label>Data:</label>
                <input type="date" name="data" id="campo_data" required>
            </div>
            <div class="form-group flex-2">
                <label>CPF:</label>
                <input type="text" id="cpf_assistido" name="cpf_assistido" placeholder="Apenas numeros" required autocomplete="off" inputmode="numeric" maxlength="14">
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Nome:</label>
                <input type="text" name="nome_assistido" id="campo_nome" required>
            </div>

            <div class="form-group">
                <label>Terapeuta Responsavel:</label>
                <input type="text" name="voluntario" required>
            </div>
        </div>

        <% if (typeof mostrarObservacoes === 'undefined' || mostrarObservacoes !== false) { %>
            <div class="form-group">
                <label><%= typeof observacoesLabel === 'undefined' ? 'Observacoes:' : observacoesLabel %></label>
                <textarea name="observacoes" id="descricao_atendimento" rows="<%= typeof observacoesRows === 'undefined' ? 4 : observacoesRows %>"></textarea>
            </div><br>
        <% } %>

        <button type="submit" class="btn-atender btn-success"><%= botaoTexto %></button>
    </form><br><br>

    <hr>
    <h3><%= historicoTitulo %></h3>
    <table class="table-historico">
        <thead>
            <tr>
                <th>Data</th>
                <th>Terapeuta</th>
                <th>Observacao</th>
            </tr>
        </thead>
        <tbody id="tabela-corpo">
            <tr><td colspan="3"><%= mensagemHistoricoInicial %></td></tr>
        </tbody>
    </table>
</main>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  const formularioConfig = {
    tipo: <%- JSON.stringify(tipo) %>,
    sucessoMensagem: <%- JSON.stringify(sucessoMensagem) %>,
    historicoVazioMensagem: <%- JSON.stringify(historicoVazioMensagem) %>,
    redirectAposSalvar: <%- JSON.stringify(redirectAposSalvar) %>,
    mostrarObservacoes: <%- JSON.stringify(typeof mostrarObservacoes === 'undefined' ? true : mostrarObservacoes !== false) %>,
    prefixoQueixa: <%- JSON.stringify(typeof prefixoQueixa !== 'undefined' ? prefixoQueixa : '') %>,
    sufixoQueixa: <%- JSON.stringify(typeof sufixoQueixa !== 'undefined' ? sufixoQueixa : '') %>
  };

  const dataHoje = new Date().toISOString().split('T')[0];
  document.getElementById('campo_data').value = dataHoje;
  const campoCpf = document.getElementById('cpf_assistido');
  let ultimoCpfSemCadastroAlertado = '';
  let ultimoCpfIncompletoAlertado = '';

  function normalizarCpf(valor) {
    return (valor || '').replace(/\D/g, '');
  }

  function cpfTem11Digitos(valor) {
    return normalizarCpf(valor).length === 11;
  }

  async function buscarAssistidoPorCpf(cpf) {
    const resposta = await fetch(`/api/dados-assistido/${cpf}`);
    if (!resposta.ok) {
      return null;
    }

    return resposta.json();
  }

  function renderizarTabela(lista) {
    const corpo = document.getElementById('tabela-corpo');
    if (!lista || lista.length === 0) {
      corpo.innerHTML = `<tr><td colspan="3">${formularioConfig.historicoVazioMensagem}</td></tr>`;
      return;
    }

    corpo.innerHTML = lista.map(item => {
      const terapeuta = item.nome_voluntario || item.voluntario || '-';
      const observacoes = item.observacoes_atendimento || item.observacoes || '-';
      return `
        <tr>
          <td>${new Date(item.data).toLocaleDateString('pt-BR')}</td>
          <td>${terapeuta}</td>
          <td>${observacoes}</td>
        </tr>
      `;
    }).join('');
  }

  campoCpf.addEventListener('blur', async function() {
    const cpf = normalizarCpf(this.value);
    if (!cpfTem11Digitos(cpf)) {
      if (cpf.length > 0 && ultimoCpfIncompletoAlertado !== cpf) {
        ultimoCpfIncompletoAlertado = cpf;
        await Swal.fire('CPF incompleto', 'Informe um CPF com 11 digitos.', 'warning');
      }
      return;
    }

    ultimoCpfIncompletoAlertado = '';
    ultimoCpfSemCadastroAlertado = '';

    document.getElementById('idSolicitacao').value = `${cpf}_${formularioConfig.tipo}_${dataHoje}`;

    try {
      const resDados = await buscarAssistidoPorCpf(cpf);
      if (!resDados) {
        document.getElementById('campo_nome').value = '';
        renderizarTabela([]);
        if (ultimoCpfSemCadastroAlertado !== cpf) {
          ultimoCpfSemCadastroAlertado = cpf;
          await Swal.fire('Assistido não encontrado', 'Este CPF ainda não está cadastrado. Faça o cadastro antes de registrar o atendimento.', 'warning');
        }
        return;
      }

      ultimoCpfSemCadastroAlertado = '';
      document.getElementById('campo_nome').value = resDados.nome_assistido || '';

      const resHist = await fetch(`/api/historico/${formularioConfig.tipo}/${cpf}`).then(r => r.json());

      if (resHist.queixa_atual && formularioConfig.prefixoQueixa && formularioConfig.mostrarObservacoes) {
        const campoObs = document.getElementById('descricao_atendimento');
        const textoQueixa = `${formularioConfig.prefixoQueixa}${resHist.queixa_atual}${formularioConfig.sufixoQueixa}`;

        if (campoObs && campoObs.value.trim() === '') {
          campoObs.value = textoQueixa;
        }
      }

      renderizarTabela(resHist.historico || []);
    } catch (err) {
      console.error('Erro ao buscar dados:', err);
    }
  });

  document.getElementById('atendimentoForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = e.target.querySelector('button');

    if (!cpfTem11Digitos(campoCpf.value)) {
      await Swal.fire('CPF invalido', 'Informe um CPF com 11 digitos antes de finalizar.', 'warning');
      campoCpf.focus();
      return;
    }

    btn.disabled = true;

    try {
      const assistido = await buscarAssistidoPorCpf(normalizarCpf(campoCpf.value));
      if (!assistido) {
        await Swal.fire('Assistido nao encontrado', 'Este CPF ainda nao esta cadastrado. Faca o cadastro antes de finalizar o atendimento.', 'warning');
        campoCpf.focus();
        btn.disabled = false;
        return;
      }

      ultimoCpfSemCadastroAlertado = '';
      const body = new URLSearchParams(new FormData(e.target));
      const resp = await fetch(e.target.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body
      });

      if (!resp.ok) {
        const erro = await resp.json().catch(() => null);
        throw new Error(erro?.mensagem || 'Falha ao salvar atendimento.');
      }

      await Swal.fire('Sucesso', formularioConfig.sucessoMensagem, 'success');

      if (formularioConfig.redirectAposSalvar === 'reload') {
        window.location.reload();
      } else {
        window.location.href = formularioConfig.redirectAposSalvar;
      }
    } catch (err) {
      Swal.fire('Erro', err.message || 'Falha ao salvar atendimento.', 'error');
      btn.disabled = false;
    }
  });
</script>

<%- include('../partials/footer') %>
