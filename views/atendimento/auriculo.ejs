<%- include('../partials/header') %>
<link rel="stylesheet" href="/styles/styles.css">
<main class="hero">
    <h1>Ficha de Atendimento - Aurículo</h1>
    
    <form action="/atendimento/salvar" method="POST" class="form-container" id="atendimentoForm">
        <input type="hidden" name="tipo" value="auriculo">
        <input type="hidden" name="idSolicitacao" id="idSolicitacao">
        
        <div class="form-row">
            <div class="form-group">
                <label>Data:</label>
                <input type="date" name="data" id="campo_data" required>
            </div>
            <div class="form-group flex-2">
                <label>CPF:</label>
                <input type="text" id="cpf_assistido" name="cpf_assistido" placeholder="Apenas números" required autocomplete="off">
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Nome:</label>
                <input type="text" name="nome_assistido" id="campo_nome" required>
            </div>

            <div class="form-group">
                <label>Terapeuta Responsável:</label>
                <input type="text" name="voluntario" required>
            </div>
        </div>

        <div class="form-group">
            <label>Evolução / Observações:</label>
            <textarea name="observacoes" id="descricao_atendimento" rows="5"></textarea>
        </div><br>

        <button type="submit" class="btn-atender btn-success">Finalizar Atendimento</button>
    </form><br><br>

    <hr>
    <h3>Histórico de Atendimentos</h3>
    <table class="table-historico">
        <thead>
            <tr>
                <th>Data</th>
                <th>Terapeuta</th>
                <th>Observação</th>
            </tr>
        </thead>
        <tbody id="tabela-corpo">
            <tr><td colspan="3">Aguardando CPF...</td></tr>
        </tbody>
    </table>
</main>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  // 1. Data Inicial
  const dataHoje = new Date().toISOString().split('T')[0];
  document.getElementById('campo_data').value = dataHoje;

  function renderizarTabela(lista) {
    const corpo = document.getElementById('tabela-corpo');
    if (!lista || lista.length === 0) {
      corpo.innerHTML = '<tr><td colspan="3">Nenhum histórico encontrado.</td></tr>';
      return;
    }
    corpo.innerHTML = lista.map(item => `
      <tr>
        <td>${new Date(item.data).toLocaleDateString('pt-BR')}</td>
        <td>${item.voluntario || '-'}</td>
        <td>${item.observacoes || '-'}</td>
      </tr>
    `).join('');
  }

  // 2. Busca de Dados (CPF Blur)
  document.getElementById('cpf_assistido').addEventListener('blur', async function() {
    const cpf = this.value.trim().replace(/\D/g, '');
    if (cpf.length < 11) return;

    // CORREÇÃO: Padronização do ID conforme a recepção (CPF_TIPO_DATA)
    const tipoTerapia = "auriculo";
    document.getElementById('idSolicitacao').value = `${cpf}_${tipoTerapia}_${dataHoje}`;

    try {
      // Busca Nome
      const resDados = await fetch(`/api/dados-assistido/${cpf}`).then(r => r.json());
      if (resDados) document.getElementById('campo_nome').value = resDados.nome_assistido || "";

      // Busca Histórico e Queixa
      const resHist = await fetch(`/api/historico/auriculo/${cpf}`).then(r => r.json());
      
      // Carrega a queixa se existir
/*       if (resHist.queixa_atual) {
          const campoObs = document.getElementById('descricao_atendimento');
          const textoQueixa = `QUEIXA DA RECEPÇÃO:\n${resHist.queixa_atual}\n-----------------------------\nOBSERVAÇÕES:\n`;
          
          if (campoObs.value.trim() === "") {
              campoObs.value = textoQueixa;
          }
      } */

      renderizarTabela(resHist.historico || []);
    } catch (err) {
      console.error('Erro ao buscar dados:', err);
    }
  });

  // 3. Envio via AJAX (Garante que o idSolicitacao seja enviado)
  document.getElementById('atendimentoForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = e.target.querySelector('button');
    btn.disabled = true;

    try {
      const body = new URLSearchParams(new FormData(e.target));
      const resp = await fetch(e.target.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body
      });

      if (resp.ok) {
        await Swal.fire('Sucesso', 'Atendimento finalizado!', 'success');
        window.location.href = '/fila-atendimento';
      } else {
        throw new Error();
      }
    } catch (err) {
      Swal.fire('Erro', 'Falha ao salvar atendimento.', 'error');
      btn.disabled = false;
    }
  });
</script>

<%- include('../partials/footer') %>