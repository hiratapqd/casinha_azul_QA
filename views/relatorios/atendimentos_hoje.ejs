<%- include('../partials/header') %>
<link rel="stylesheet" href="/styles/styles.css">

<style>
    .container { max-width: 1200px; margin: 20px auto; font-family: 'Segoe UI', Arial, sans-serif; padding: 0 15px; }
    
    /* Abas Estilo Cápsula */
    .tabs { display: flex; gap: 10px; margin: 20px 0; flex-wrap: wrap; }
    .tab { 
        padding: 10px 18px; 
        border: 1px solid #ddd; 
        border-radius: 25px; 
        cursor: pointer; 
        background: #fff; 
        font-weight: 600;
        color: #555;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
    }
    .tab:hover { background: #f0f7ff; border-color: #1277bb; color: #1277bb; }
    .tab.active { background: #1277bb; color: #fff; border-color: #1277bb; box-shadow: 0 4px 10px rgba(18,119,187,0.3); }

    .pill { 
        background: rgba(0,0,0,0.05); 
        padding: 2px 8px; 
        border-radius: 12px; 
        font-size: 12px; 
        margin-left: 8px; 
    }
    .tab.active .pill { background: rgba(255,255,255,0.2); color: #fff; }

    /* Tabela Profissional */
    .table-container { overflow-x: auto; background: #fff; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
    table { width: 100%; border-collapse: collapse; }
    th { 
        background-color: #1277bb !important; 
        color: white !important; 
        padding: 14px; 
        text-align: left; 
        text-transform: uppercase;
        font-size: 13px;
    }
    td { padding: 12px 14px; border-bottom: 1px solid #eee; font-size: 14px; }
    tbody tr:nth-child(even) { background-color: #f9f9f9; }
    tbody tr:hover { background-color: #f1f7ff; }

    .search-row { margin-bottom: 20px; display: flex; gap: 10px; align-items: center; }
    input#search { padding: 10px; width: 300px; border: 1px solid #ddd; border-radius: 8px; }
    .counter-info { font-weight: bold; color: #1277bb; }
</style>

<div class="container">
    <h2>Relatório de Atendimentos - <%= hoje %></h2>



    <div class="tabs">
        <% tabs.forEach(t => { %>
            <div class="tab <%= t.slug === '__todos' ? 'active' : '' %>" data-tipo="<%= t.slug %>">
                <%= t.nome %>
                <span class="pill"><%= (counts && counts[t.slug] !== undefined) ? counts[t.slug] : (t.slug === '__todos' ? atendimentos.length : 0) %></span>
            </div>
        <% }) %>
    </div>
    <div class="search-row">
        <input type="text" id="search" placeholder="🔍 Buscar por nome, CPF ou Terapeuta...">
        <span class="counter-info">Mostrando: <span id="qt">0</span> atendimentos</span>
    </div>
    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>Data/Hora</th>
                    <th>Tipo</th>
                    <th>CPF</th>
                    <th>Assistido</th>
                    <th>Terapeuta</th>
                    <th>Observações</th>
                </tr>
            </thead>
            <tbody id="tbody">
                </tbody>
        </table>
    </div>
</div>

<script>
    const atendimentos = <%- JSON.stringify(atendimentos) %>;
    let tipoAtual = "__todos";
    const tbody = document.getElementById("tbody");
    const qt = document.getElementById("qt");
    const searchInput = document.getElementById("search");
    const tabs = document.querySelectorAll(".tab");

    function fmt(dateStr) {
        return new Date(dateStr).toLocaleString('pt-BR', { hour: '2-digit', minute: '2-digit' });
    }

    function filtrar() {
        const term = searchInput.value.toLowerCase().trim();
        tbody.innerHTML = "";
        let count = 0;

        atendimentos.forEach(a => {
            const tipoA = a.tipo ? a.tipo.trim().toLowerCase() : "";
            
            // Filtro por Aba
            if (tipoAtual !== "__todos" && tipoA !== tipoAtual) return;

            // Filtro por Texto
            const textoBusca = `${a.nome_assistido} ${a.cpf_assistido} ${a.voluntario}`.toLowerCase();
            if (term && !textoBusca.includes(term)) return;

            const tr = document.createElement("tr");
            tr.innerHTML = `
                <td>${fmt(a.data)}</td>
                <td style="text-transform: capitalize;">${a.tipo}</td>
                <td>${a.cpf_assistido}</td>
                <td><strong>${a.nome_assistido}</strong></td>
                <td>${a.voluntario}</td>
                <td class="muted">${a.observacoes || ''}</td>
            `;
            tbody.appendChild(tr);
            count++;
        });
        qt.textContent = count;
    }

    tabs.forEach(t => {
        t.addEventListener("click", () => {
            tabs.forEach(x => x.classList.remove("active"));
            t.classList.add("active");
            tipoAtual = t.getAttribute("data-tipo");
            filtrar();
        });
    });

    searchInput.addEventListener("input", filtrar);
    window.onload = filtrar;
</script>

<%- include('../partials/footer') %>