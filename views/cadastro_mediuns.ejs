<%- include('partials/header') %>
    <link rel="stylesheet" href="/styles/styles.css">
<main class="hero">
    <h1>Cadastro dos mediuns</h1>
    <!-- <form action="/medium/novo" method="POST" class="form-container"> -->
    <form id="formVoluntario" action="/medium/novo" method="POST" class="form-container">
        <input type="hidden" id="forceUpdate" name="forceUpdate" value="false">
    <div class="form-row">
        <div class="form-group">
            <label for="nome">Nome Completo:</label>
            <input type="text" id="nome" name="nome" required>
        </div><br>

        <div class="form-group">
            <label for="cpf">CPF:</label>
            <input type="text" id="cpf" name="cpf" placeholder="000.000.000-00" required>
        </div><br>
    </div><br>
    <div class="form-row">
        <div class="form-group">
            <label for="telefone">Telefone/WhatsApp:</label>
            <input type="tel" id="telefone" name="telefone">
        </div><br>

        <div class="form-group">
            <label for="email">E-mail:</label>
            <input type="email" id="email" name="email">
        </div><br>
    </div><br>
        <div class="form-group">
            <label for="mediunidade">Mediunidade:</label>
            <input type="text" id="mediunidade" name="mediunidade">
            <label for="mediunidade">separe por vigula no caso de mais de uma</label>
        </div><br>

<div class="disponibilidade-secao">
    <h2>Disponibilidade por Modalidade</h2>
    <p>Selecione os dias da semana para cada atividade que deseja realizar:</p>

    <% 
        const modalidades = [
            { id: 'apometria', label: 'Apometria' },
            { id: 'reiki', label: 'Reiki' },
            { id: 'auriculo', label: 'Aurículo' },
            { id: 'maos', label: 'Mãos Sem Fronteiras' },
            { id: 'homeopatia', label: 'Homeopatia' },
            { id: 'cantina', label: 'Cantina' },
            { id: 'passe', label: 'Passe' },
            { id: 'mesa', label: 'Mesa' }
        ];
        const dias = ['Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb', 'Dom'];
    %>

    <div class="grade-container">
        <% modalidades.forEach(mod => { %>
            <div class="linha-modalidade">
                <span class="label-modalidade"><%= mod.label %></span>
                <div class="checkbox-group">
                    <% dias.forEach(dia => { %>
                        <label class="check-item">
                            <!-- <input type="checkbox" name="voluntario_<%= mod.id %>_dias" value="<%= dia.toLowerCase() %>"> -->
                             <input type="checkbox" name="disp_<%= mod.id %>" value="<%= dia.toLowerCase() %>">
                            <span><%= dia %></span>
                        </label>
                    <% }) %>
                </div>
            </div>
        <% }) %>
    </div>
</div>


    </div><br>
        <button type="submit" class="btn-atender btn-success">Finalizar Cadastro do medium</button>
    </form>


<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    const form = document.getElementById('formVoluntario');

    form.addEventListener('submit', async (e) => {
        e.preventDefault(); // Impede o envio padrão que causa a página branca
        
        const formData = new FormData(form);
        const dados = Object.fromEntries(formData.entries());

        // Captura manual das disponibilidades para garantir o formato de Array no MongoDB
        const terapias = ['apometria', 'reiki', 'auriculo', 'maos', 'homeopatia', 'passe', 'cantina', 'mesa'];
        terapias.forEach(terapia => {
            // Busca pelos checkboxes que agora seguem o padrão name="disp_terapia"
            const marcados = Array.from(form.querySelectorAll(`input[name="disp_${terapia}"]:checked`))
                                  .map(cb => cb.value);
            dados[`disp_${terapia}`] = marcados; 
        });

        try {
            const resposta = await fetch('/medium/novo', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(dados)
            });

            const resultado = await resposta.json();

            if (resultado.status === 'conflito') {
                Swal.fire({
                    title: 'CPF já cadastrado!',
                    text: "Deseja atualizar os dados deste voluntário?",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'Sim, atualizar!',
                    cancelButtonText: 'Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        document.getElementById('forceUpdate').value = 'true';
                        form.requestSubmit(); // Reenvia o formulário com o flag de atualização
                    }
                });
            } else if (resultado.status === 'sucesso') {
                Swal.fire('Sucesso!', 'Dados gravados com sucesso.', 'success')
                    .then(() => window.location.href = '/cadastro_mediuns');
            }
        } catch (err) {
            console.error("Erro no envio:", err);
            Swal.fire('Erro!', 'Falha ao comunicar com o servidor.', 'error');
        }
    });
</script>

</main>
<%- include('partials/footer') %>
