<%- include('../partials/header') %>

<link rel="stylesheet" href="/styles/styles.css">

<div class="container">
    <div class="hero">
        <h1>Estoque da Livraria</h1>
        <p>Gerencie os títulos disponíveis no centro</p>
    </div>

    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 30px;">
        <div class="card" style="border-top: 5px solid #1277bb; text-align: center;">
            <h3 style="color: #666; font-size: 0.9em;">TOTAL DE VENDAS NO MÊS</h3>
            <p style="font-size: 1.8em; font-weight: bold; color: #1277bb; margin: 10px 0;">
                R$ <%= totalVendidoMes.toFixed(2) %>
            </p>
        </div>

        <div class="card" style="border-top: 5px solid #28a745;">
            <h3 style="color: #666; font-size: 0.9em; text-align: center;">TOP 5 mais vendidos neste Mês</h3>
            <ul style="list-style: none; padding: 0; margin-top: 10px; font-size: 0.85em;">
                <% top5.forEach(([titulo, qtd], index) => { %>
                    <li style="margin-bottom: 5px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                        <strong><%= index + 1 %>º</strong> <%= titulo %> (<%= qtd %>)
                    </li>
                <% }) %>
            </ul>
        </div>

        <div class="card" style="border-top: 5px solid #ff4d4d; text-align: center;">
            <h3 style="color: #666; font-size: 0.9em;">AVISO DE REPOSIÇÃO</h3>
            <p style="font-size: 2em; font-weight: bold; color: #ff4d4d; margin: 10px 0;">
                <%= totalAlertas %>
            </p>
            <small style="color: #999;">Livros abaixo da média de giro</small>
        </div>
    </div>

    <div class="card" style="margin-bottom: 20px; padding: 15px;">
        <div style="display: flex; gap: 15px; align-items: center; justify-content: space-between; flex-wrap: wrap;">
            
            <div style="display: flex; align-items: center; gap: 10px; flex: 1; min-width: 300px; position: relative;">
                <i class="fas fa-search" style="position: absolute; left: 15px; color: #1277bb;"></i>
                <input type="text" id="inputBusca" placeholder="Buscar por Título, Autor ou ISBN..." 
                    style="width: 100%; padding: 12px 12px 12px 40px; border: 1px solid #ddd; border-radius: 8px; font-size: 1rem;">
            </div>

            <a href="/livraria/cadastro" class="btn-atender btn-success" style="text-decoration: none; display: flex; align-items: center; gap: 8px; white-space: nowrap; height: 45px;">
                <i class="fas fa-plus"></i> Cadastrar Novo Livro
            </a>

        </div>
    </div>   

    <div class="card">
        <table>
            <thead>
                <tr>
                    <th>Capa</th>
                    <th>Título</th>
                    <th>Editora</th>
                    <th>Autor / Espírito</th>
                    <th>Estoque</th>
                    <th>Preço Venda</th>
                    <th>Giro (90/180/365d)</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                <% livros.forEach(livro => { %>
                <tr>
                    <td>
                        <img src="https://covers.openlibrary.org/b/isbn/<%= livro._id %>-S.jpg"
                             loading="lazy"
                             referrerpolicy="no-referrer"
                             onerror="this.onerror=null;this.src='data:image/svg+xml;utf8,<svg xmlns=&quot;http://www.w3.org/2000/svg&quot; width=&quot;40&quot; height=&quot;60&quot; viewBox=&quot;0 0 40 60&quot;><rect width=&quot;40&quot; height=&quot;60&quot; fill=&quot;%23f1f3f5&quot;/><text x=&quot;20&quot; y=&quot;32&quot; font-size=&quot;10&quot; text-anchor=&quot;middle&quot; fill=&quot;%23666&quot; font-family=&quot;Arial&quot;>N/A</text></svg>'"
                             width="40" style="border-radius: 4px;">
                    </td>
                    
                    <td><strong><%= livro.titulo %></strong><br><small style="color:#999"><%= livro._id %></small></td>
                    
                    <td><span class="badge-editora"><%= livro.editora || '---' %></span></td>
                    
                    <td>
                        <%= livro.autor %><br>
                        <small style="color: #666;">
                            <%= livro.ditadoPor ? 'Espírito: ' + livro.ditadoPor : '' %>
                        </small>
                    </td>

                    <td>
                        <span id="estoque-<%= livro._id %>" class="status-badge <%= livro.estoque_atual <= (livro.estoque_minimo || 2) ? 'alerta' : 'atendimento' %>">
                            <%= livro.estoque_atual %> un
                        </span>
                    </td>

                    <td>R$ <%= livro.preco_venda.toFixed(2) %></td>

                    <td>
                        <div style="font-size: 0.9em; display: flex; gap: 5px;">
                            <span title="90 dias" style="color: #1277bb; font-weight: bold;"><%= livro.vendas90 %></span>
                            <span style="color: #ccc;">|</span>
                            <span title="180 dias" style="color: #666;"><%= livro.vendas180 %></span>
                            <span style="color: #ccc;">|</span>
                            <span title="365 dias" style="color: #999;"><%= livro.vendas365 %></span>
                        </div>
                    </td>

                    <td>
                        <div style="display: flex; gap: 10px; align-items: center;">
                            <a href="/livraria/editar/<%= livro._id %>" class="muted">Editar</a>
                            <div style="display: flex; gap: 5px; align-items: center; border-left: 1px solid #ddd; padding-left: 10px;">
                                <input type="number" id="qtd-<%= livro._id %>" value="1" min="1" style="width: 40px; text-align: center;">
                                <button type="button" onclick="vender('<%= livro._id %>', <%= livro.estoque_minimo || 2 %>)" class="btn-atender btn-success" style="background-color: #28a745; padding: 5px 10px; font-size: 12px;">
                                    Vender
                                </button>
                            </div>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
async function vender(isbn, estoqueMinimo) {
    const inputQtd = document.getElementById(`qtd-${isbn}`);
    const badgeEstoque = document.getElementById(`estoque-${isbn}`);
    const qtd = parseInt(inputQtd.value, 10);

    if (!qtd || qtd < 1) {
        Swal.fire('Atenção', 'Informe uma quantidade válida para venda.', 'warning');
        return;
    }

    try {
        const response = await fetch('/livraria/venda-rapida', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ isbn, qtd })
        });

        const resultado = await response.json();

        if (!response.ok || !resultado.sucesso) {
            Swal.fire('Erro', resultado.erro || 'Não foi possível processar a venda.', 'error');
            return;
        }

        badgeEstoque.textContent = `${resultado.novoEstoque} un`;
        badgeEstoque.className = `status-badge ${resultado.novoEstoque <= estoqueMinimo ? 'alerta' : 'atendimento'}`;
        inputQtd.value = 1;

        Swal.fire('Sucesso', 'Venda registrada com sucesso.', 'success').then(() => {
            window.location.href = '/livraria/estoque';
        });
    } catch (error) {
        Swal.fire('Erro', 'Falha ao processar a venda.', 'error');
    }
}

document.addEventListener('DOMContentLoaded', function() {
    const inputBusca = document.getElementById('inputBusca');

    if (!inputBusca) return; // Segurança caso o ID mude

function executarFiltro() {
    const termo = inputBusca.value.toLowerCase().trim();
    // Selecionamos todas as linhas do corpo da tabela, independente da classe
    const linhas = document.querySelectorAll('table tbody tr'); 

    linhas.forEach(linha => {
        if (linha.cells.length > 1) {
            const textoLinha = linha.innerText.toLowerCase();
            const textoSemPontos = textoLinha.replace(/[\.\-\/]/g, "");
            const termoSemPontos = termo.replace(/[\.\-\/]/g, "");

            if (textoLinha.includes(termo) || textoSemPontos.includes(termoSemPontos)) {
                linha.style.display = "";
            } else {
                linha.style.display = "none";
            }
        }
    });
}

    // Ouvintes de eventos para capturar qualquer mudança
    inputBusca.addEventListener('keyup', executarFiltro);
    inputBusca.addEventListener('input', executarFiltro); // Captura preenchimento automático
    inputBusca.addEventListener('paste', () => setTimeout(executarFiltro, 100));
    inputBusca.addEventListener('change', executarFiltro);
});
</script>
<%- include('../partials/footer') %>
