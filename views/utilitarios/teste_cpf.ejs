<%- include('../partials/header') %>
<link rel="stylesheet" href="/styles/styles.css">
<input type="text" name="cpf" placeholder="000.000.000-00" value="<%= cpfTestado %>" required autofocus>
<main class="hero">
    <h1>Validador de CPF (Ambiente de Teste)</h1>
    <p>Use esta página para garantir que a lógica do <code>cpfValidator.js</code> está funcionando antes de aplicar no cadastro oficial.</p>

    <div class="form-container" style="max-width: 500px; margin: 0 auto;">
        <form action="/utilitarios/teste-cpf" method="POST">
            <div class="form-group">
                <label>Digite o CPF para testar:</label>
                <input type="text" name="cpf" placeholder="000.000.000-00" value="<%= cpfTestado %>" required autofocus>
            </div>
            <button type="submit" class="btn-atender btn-success" style="width: 100%; margin-top: 15px;">
                Verificar Lógica
            </button>
        </form>

        <% if (resultado) { %>
            <div style="margin-top: 20px; padding: 20px; border-radius: 8px; text-align: center; font-size: 1.2rem; font-weight: bold; 
                background: <%= resultado.includes('✅') ? '#d4edda' : '#f8d7da' %>; 
                color: <%= resultado.includes('✅') ? '#155724' : '#721c24' %>;">
                <%= resultado %>
            </div>
        <% } %>
    </div>

    <div style="margin-top: 40px; color: #666; font-size: 0.9rem;">
        <h3>Regras aplicadas no teste:</h3>
        <ul>
            <li>Remoção de caracteres não numéricos (pontos e traços).</li>
            <li>Bloqueio de sequências repetidas (ex: 111.111.111-11).</li>
            <li>Cálculo matemático dos dois dígitos verificadores finais.</li>
        </ul>
    </div>
</main>

<%- include('../partials/footer') %>